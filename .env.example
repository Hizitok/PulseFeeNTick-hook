# RPC endpoint
RPC_URL=

# Deployer private key — NEVER commit a real key
PRIVATE_KEY=

# Uniswap v4 pool manager address on target chain
POOL_MANAGER_ADDRESS=

# Protocol admin address
ADMIN_ADDRESS=

# Fee parameters (in 1e6 units; 1% = 10000, 0.05% = 500)
MIN_FEE=500
MAX_FEE=10000
FEE_CONSTANT_C=3000

# Volume base token: true = token0, false = token1
BASE_TOKEN_IS_TOKEN0=true
